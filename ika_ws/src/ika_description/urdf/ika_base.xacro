<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- base_footprint: yer duzleminde proje noktasi -->
  <link name="base_footprint"/>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 ${wheel_radius}" rpy="0 0 0"/>
  </joint>

  <!-- base_link: arac govdesi.
       NOT: base_link tekerlek aksi yuksekliginde (base_footprint_joint
       z=wheel_radius). Govdeyi tekerlekler USTUNE yerlestirmek icin
       visual/collision z offset = wheel_radius + clearance + robot_height/2.
       Boylece govdenin altı tekerlek ust kenarinin biraz uzerinde durur,
       tekerlekler gozle goruluyor olur. -->
  <xacro:property name="chassis_clearance" value="0.005"/>
  <xacro:property name="chassis_z" value="${wheel_radius + chassis_clearance + robot_height/2}"/>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 ${chassis_z}"/>
      <geometry>
        <box size="${robot_length} ${robot_width} ${robot_height}"/>
      </geometry>
      <material name="ika_body"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${chassis_z}"/>
      <geometry>
        <box size="${robot_length} ${robot_width} ${robot_height}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="${base_mass}"/>
      <origin xyz="0 0 ${chassis_z}"/>
      <inertia
        ixx="${base_mass*(robot_width*robot_width + robot_height*robot_height)/12.0}" ixy="0" ixz="0"
        iyy="${base_mass*(robot_length*robot_length + robot_height*robot_height)/12.0}" iyz="0"
        izz="${base_mass*(robot_length*robot_length + robot_width*robot_width)/12.0}"/>
    </inertial>
  </link>

  <!-- 4 teker makrosu -->
  <xacro:macro name="wheel" params="prefix x_offset y_offset">
    <link name="${prefix}_wheel">
      <visual>
        <origin rpy="${pi/2} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <material name="ika_wheel"/>
      </visual>
      <collision>
        <origin rpy="${pi/2} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </collision>
      <xacro:cylinder_inertial mass="${wheel_mass}" r="${wheel_radius}" l="${wheel_width}"/>
    </link>

    <joint name="${prefix}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${prefix}_wheel"/>
      <origin xyz="${x_offset} ${y_offset} 0" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <dynamics damping="0.1" friction="0.05"/>
    </joint>
  </xacro:macro>

  <!-- Skid-steer: 4 teker, sol/sag gruplar es-yonlu -->
  <xacro:wheel prefix="front_left"  x_offset="${ wheel_track/2}" y_offset="${ wheel_base/2 + wheel_width/2}"/>
  <xacro:wheel prefix="front_right" x_offset="${ wheel_track/2}" y_offset="${-wheel_base/2 - wheel_width/2}"/>
  <xacro:wheel prefix="back_left"   x_offset="${-wheel_track/2}" y_offset="${ wheel_base/2 + wheel_width/2}"/>
  <xacro:wheel prefix="back_right"  x_offset="${-wheel_track/2}" y_offset="${-wheel_base/2 - wheel_width/2}"/>

</robot>
