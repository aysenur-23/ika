<?xml version="1.0"?>
<sdf version="1.10">
  <world name="ika_test_world">

    <physics name="1ms" type="ignored">
      <max_step_size>0.002</max_step_size>
      <real_time_factor>1.0</real_time_factor>
    </physics>

    <plugin filename="gz-sim-physics-system" name="gz::sim::systems::Physics"/>
    <plugin filename="gz-sim-user-commands-system" name="gz::sim::systems::UserCommands"/>
    <plugin filename="gz-sim-scene-broadcaster-system" name="gz::sim::systems::SceneBroadcaster"/>
    <plugin filename="gz-sim-contact-system" name="gz::sim::systems::Contact"/>
    <plugin filename="gz-sim-imu-system" name="gz::sim::systems::Imu"/>
    <plugin filename="gz-sim-sensors-system" name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>
    <plugin filename="gz-sim-navsat-system" name="gz::sim::systems::NavSat"/>

    <gravity>0 0 -9.81</gravity>
    <magnetic_field>6e-06 2.3e-05 -4.2e-05</magnetic_field>

    <scene>
      <ambient>0.6 0.6 0.6 1</ambient>
      <background>0.7 0.8 0.9 1</background>
      <grid>false</grid>
    </scene>

    <light type="directional" name="sun">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.9 0.9 0.9 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <direction>-0.5 0.1 -0.9</direction>
    </light>

    <spherical_coordinates>
      <surface_model>EARTH_WGS84</surface_model>
      <world_frame_orientation>ENU</world_frame_orientation>
      <latitude_deg>41.015137</latitude_deg>
      <longitude_deg>28.979530</longitude_deg>
      <elevation>40.0</elevation>
    </spherical_coordinates>

    <!-- Zemin -->
    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry><plane><normal>0 0 1</normal><size>40 40</size></plane></geometry>
          <surface>
            <friction>
              <ode><mu>1.0</mu><mu2>1.0</mu2></ode>
            </friction>
          </surface>
        </collision>
        <visual name="visual">
          <geometry><plane><normal>0 0 1</normal><size>40 40</size></plane></geometry>
          <material>
            <ambient>0.45 0.45 0.45 1</ambient>
            <diffuse>0.55 0.55 0.55 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Statik engel kutulari -->
    <model name="obstacle_box_1">
      <static>true</static>
      <pose>3.0 1.0 0.25 0 0 0</pose>
      <link name="link">
        <collision name="c"><geometry><box><size>0.5 0.5 0.5</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>0.5 0.5 0.5</size></box></geometry>
          <material><ambient>0.7 0.3 0.2 1</ambient><diffuse>0.7 0.3 0.2 1</diffuse></material>
        </visual>
      </link>
    </model>
    <model name="obstacle_box_2">
      <static>true</static>
      <pose>4.5 -1.5 0.25 0 0 0.7</pose>
      <link name="link">
        <collision name="c"><geometry><box><size>0.5 0.5 0.5</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>0.5 0.5 0.5</size></box></geometry>
          <material><ambient>0.7 0.3 0.2 1</ambient><diffuse>0.7 0.3 0.2 1</diffuse></material>
        </visual>
      </link>
    </model>
    <model name="obstacle_box_3">
      <static>true</static>
      <pose>6.0 0.5 0.4 0 0 0</pose>
      <link name="link">
        <collision name="c"><geometry><box><size>0.8 0.8 0.8</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>0.8 0.8 0.8</size></box></geometry>
          <material><ambient>0.7 0.3 0.2 1</ambient><diffuse>0.7 0.3 0.2 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- Rampa: %10 (~5.7 derece) — guvenli sinif testi -->
    <model name="ramp_safe">
      <static>true</static>
      <pose>2.5 -3.0 0.15 0 -0.10 0</pose>
      <link name="link">
        <collision name="c"><geometry><box><size>3.0 1.5 0.3</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>3.0 1.5 0.3</size></box></geometry>
          <material><ambient>0.4 0.5 0.4 1</ambient><diffuse>0.4 0.5 0.4 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- Rampa: %30 (~17 derece) — caution sinif testi -->
    <model name="ramp_caution">
      <static>true</static>
      <pose>7.5 -3.0 0.30 0 -0.30 0</pose>
      <link name="link">
        <collision name="c"><geometry><box><size>2.0 1.5 0.6</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>2.0 1.5 0.6</size></box></geometry>
          <material><ambient>0.6 0.5 0.3 1</ambient><diffuse>0.6 0.5 0.3 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- Cukur kenari simulasyonu: platform + bos alan -->
    <model name="dropoff_platform">
      <static>true</static>
      <pose>-3.0 0.0 0.25 0 0 0</pose>
      <link name="link">
        <collision name="c"><geometry><box><size>3.0 3.0 0.5</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>3.0 3.0 0.5</size></box></geometry>
          <material><ambient>0.3 0.3 0.5 1</ambient><diffuse>0.3 0.3 0.5 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- Dar gecit: iki duvar arasi yaklasik 0.6m -->
    <model name="wall_left">
      <static>true</static>
      <pose>2.0 3.4 0.35 0 0 0</pose>
      <link name="link">
        <collision name="c"><geometry><box><size>1.5 0.10 0.7</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>1.5 0.10 0.7</size></box></geometry>
          <material><ambient>0.5 0.5 0.5 1</ambient><diffuse>0.5 0.5 0.5 1</diffuse></material>
        </visual>
      </link>
    </model>
    <model name="wall_right">
      <static>true</static>
      <pose>2.0 2.7 0.35 0 0 0</pose>
      <link name="link">
        <collision name="c"><geometry><box><size>1.5 0.10 0.7</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>1.5 0.10 0.7</size></box></geometry>
          <material><ambient>0.5 0.5 0.5 1</ambient><diffuse>0.5 0.5 0.5 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- =============================================================
         Tez engel taksonomisi - 7 sinif (bkz. TEST_PROTOKOLU.md)
         ============================================================= -->

    <!-- [Sinif 1] Sabit engel: ince direk (PVC boru benzeri) -->
    <!-- Lidar'in ince-engel cozumunurlugunu sinar; obstacle_layer'da isaretlenir. -->
    <model name="thin_pole_1">
      <static>true</static>
      <pose>3.0 -0.8 0.7 0 0 0</pose>
      <link name="link">
        <collision name="c"><geometry><cylinder><radius>0.04</radius><length>1.4</length></cylinder></geometry></collision>
        <visual name="v"><geometry><cylinder><radius>0.04</radius><length>1.4</length></cylinder></geometry>
          <material><ambient>0.85 0.75 0.15 1</ambient><diffuse>0.85 0.75 0.15 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- [Sinif 4] Yukselti / esik: 8 cm kaldirim benzeri eşik -->
    <!-- ika_terrain'in max_step_height_m esigi etrafinda sinif sinir testi. -->
    <model name="kerb_step_1">
      <static>true</static>
      <pose>3.5 -3.5 0.04 0 0 0</pose>
      <link name="link">
        <collision name="c"><geometry><box><size>1.5 0.40 0.08</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>1.5 0.40 0.08</size></box></geometry>
          <material><ambient>0.55 0.55 0.55 1</ambient><diffuse>0.55 0.55 0.55 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- [Sinif 5] Dinamik engel (gorsel): statik insan modeli -->
    <!-- Govde silindir + kafa kuresi. Sim_detection_node ile esleyince DL
         hattinin tepkisi olcum altina alinir. Gercek dinamik hareket
         sim_detection_params.yaml'da scripted (virtual) olarak yapilir. -->
    <model name="person_static_1">
      <static>true</static>
      <pose>5.0 2.0 0.0 0 0 0</pose>
      <link name="link">
        <collision name="body"><pose>0 0 0.45 0 0 0</pose>
          <geometry><cylinder><radius>0.20</radius><length>0.90</length></cylinder></geometry></collision>
        <visual name="body_v"><pose>0 0 0.45 0 0 0</pose>
          <geometry><cylinder><radius>0.20</radius><length>0.90</length></cylinder></geometry>
          <material><ambient>0.20 0.30 0.70 1</ambient><diffuse>0.20 0.30 0.70 1</diffuse></material>
        </visual>
        <collision name="head"><pose>0 0 1.05 0 0 0</pose>
          <geometry><sphere><radius>0.13</radius></sphere></geometry></collision>
        <visual name="head_v"><pose>0 0 1.05 0 0 0</pose>
          <geometry><sphere><radius>0.13</radius></sphere></geometry>
          <material><ambient>0.92 0.74 0.55 1</ambient><diffuse>0.92 0.74 0.55 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- [Sinif 6] Kor koridor / L-tipi engel dizilimi -->
    <!-- SLAM ile haritalanip donus + alternatif rota arama testi. -->
    <model name="l_corridor_wall_a">
      <static>true</static>
      <pose>-4.0 3.0 0.35 0 0 0</pose>
      <link name="link">
        <collision name="c"><geometry><box><size>2.0 0.10 0.7</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>2.0 0.10 0.7</size></box></geometry>
          <material><ambient>0.50 0.50 0.50 1</ambient><diffuse>0.50 0.50 0.50 1</diffuse></material>
        </visual>
      </link>
    </model>
    <model name="l_corridor_wall_b">
      <static>true</static>
      <pose>-5.0 3.6 0.35 0 0 1.5708</pose>
      <link name="link">
        <collision name="c"><geometry><box><size>1.4 0.10 0.7</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>1.4 0.10 0.7</size></box></geometry>
          <material><ambient>0.50 0.50 0.50 1</ambient><diffuse>0.50 0.50 0.50 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- [Sinif 7] Riskli zemin: renk yamasi gostergeleri -->
    <!-- Tezdeki sinif: SAFE/CAUTION/RISKY. Su an gorsel - kamera tabanli
         yuzey siniflandirici (RGB renk/doku) sonraki faz; geometrik terrain
         RANSAC bu yamalardan etkilenmez (sadece visual cue). -->
    <model name="surface_patch_safe">
      <static>true</static>
      <pose>5.0 4.8 0.005 0 0 0</pose>
      <link name="link">
        <visual name="v"><geometry><box><size>1.0 1.0 0.01</size></box></geometry>
          <material><ambient>0.30 0.70 0.30 1</ambient><diffuse>0.30 0.70 0.30 1</diffuse></material>
        </visual>
      </link>
    </model>
    <model name="surface_patch_caution">
      <static>true</static>
      <pose>6.2 4.8 0.005 0 0 0</pose>
      <link name="link">
        <visual name="v"><geometry><box><size>1.0 1.0 0.01</size></box></geometry>
          <material><ambient>0.85 0.75 0.20 1</ambient><diffuse>0.85 0.75 0.20 1</diffuse></material>
        </visual>
      </link>
    </model>
    <model name="surface_patch_risky">
      <static>true</static>
      <pose>7.4 4.8 0.005 0 0 0</pose>
      <link name="link">
        <visual name="v"><geometry><box><size>1.0 1.0 0.01</size></box></geometry>
          <material><ambient>0.75 0.25 0.25 1</ambient><diffuse>0.75 0.25 0.25 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- [Sinif 3] Negatif engel ek senaryolari -->

    <!-- (3a) On taraf derinlik-tabanli cukur testi:
         Yukseltilmis 2x2 m platform (30 cm). Robot platforma cikip on
         kenara baktiginda RANSAC DROPOFF_DANGER tetikler. Mevcut arkadaki
         dropoff_platform (-3, 0) ek olarak, on tarafta da test edilir. -->
    <model name="pit_platform_forward">
      <static>true</static>
      <pose>7.0 1.5 0.15 0 0 0</pose>
      <link name="link">
        <collision name="c"><geometry><box><size>2.0 2.0 0.30</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>2.0 2.0 0.30</size></box></geometry>
          <material><ambient>0.30 0.30 0.50 1</ambient><diffuse>0.30 0.30 0.50 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- (3b) Gorsel cukur isaretleri (asfalt/zemin uzerinde koyu lekeler):
         RANSAC depth-tabanli tespit ETMEZ (gercek bir cukur degil, gorsel),
         ancak ileride RGB yuzey siniflandirici (Sinif 7) bunlari koyu/risky
         olarak isaretler. Tez sunumu icin sahne zenginligi. -->
    <model name="pothole_visual_1">
      <static>true</static>
      <pose>5.5 1.5 0.003 0 0 0</pose>
      <link name="link">
        <visual name="v">
          <geometry><cylinder><radius>0.35</radius><length>0.005</length></cylinder></geometry>
          <material><ambient>0.08 0.08 0.08 1</ambient><diffuse>0.08 0.08 0.08 1</diffuse></material>
        </visual>
      </link>
    </model>
    <model name="pothole_visual_2">
      <static>true</static>
      <pose>4.5 -0.5 0.003 0 0 0</pose>
      <link name="link">
        <visual name="v">
          <geometry><cylinder><radius>0.28</radius><length>0.005</length></cylinder></geometry>
          <material><ambient>0.10 0.10 0.10 1</ambient><diffuse>0.10 0.10 0.10 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- (3c) Gorsel uzun yarik (trench/kanal) -->
    <model name="trench_visual_1">
      <static>true</static>
      <pose>6.0 -2.5 0.003 0 0 0.3</pose>
      <link name="link">
        <visual name="v">
          <geometry><box><size>1.8 0.18 0.005</size></box></geometry>
          <material><ambient>0.06 0.06 0.06 1</ambient><diffuse>0.06 0.06 0.06 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- (3d) Tehlike konisi: gorsel cukur yanina, sahne icin -->
    <model name="hazard_cone_1">
      <static>true</static>
      <pose>5.5 2.1 0.0 0 0 0</pose>
      <link name="link">
        <collision name="c"><pose>0 0 0.20 0 0 0</pose>
          <geometry><cylinder><radius>0.10</radius><length>0.40</length></cylinder></geometry></collision>
        <visual name="v"><pose>0 0 0.20 0 0 0</pose>
          <geometry><cylinder><radius>0.10</radius><length>0.40</length></cylinder></geometry>
          <material><ambient>0.95 0.45 0.10 1</ambient><diffuse>0.95 0.45 0.10 1</diffuse></material>
        </visual>
      </link>
    </model>
    <model name="hazard_cone_2">
      <static>true</static>
      <pose>4.5 0.1 0.0 0 0 0</pose>
      <link name="link">
        <collision name="c"><pose>0 0 0.18 0 0 0</pose>
          <geometry><cylinder><radius>0.08</radius><length>0.36</length></cylinder></geometry></collision>
        <visual name="v"><pose>0 0 0.18 0 0 0</pose>
          <geometry><cylinder><radius>0.08</radius><length>0.36</length></cylinder></geometry>
          <material><ambient>0.95 0.45 0.10 1</ambient><diffuse>0.95 0.45 0.10 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- NOT: [Sinif 2] Yakin mesafe kritik engel ayri model gerektirmez -
         mevcut kutu/duvarlardan birine yaklasildiginda Nav2 collision_monitor
         devreye girer (nav2_params.yaml). Stop_zone_distance_m esigi testi.

         [Sinif 3] Negatif engel - mevcut dropoff_platform (-3, 0) + yeni
         pit_platform_forward (7, 1.5) RANSAC depth-tabanli DROPOFF_DANGER
         testleri. Gorsel pothole/trench/cone sahne icin (Sinif 7 yuzey
         siniflandirici sonraki faz). -->

  </world>
</sdf>
