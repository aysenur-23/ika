<?xml version="1.0"?>
<sdf version="1.10">
  <world name="ika_test_world">

    <!-- =================================================================
         IKA Engel Kacinma — DINAMIK PARKUR (centerline obstacles)
         =================================================================
         Tum engeller y=0 hattinda (centerline). Robot dolanip atlamak
         icin sirayla SAGA-SOLA donmek zorunda. Tezdeki dinamik tepki
         demosu icin idealdir.

         Start ve finish kapilari ayni hizada (y=0 merkezli, simetrik).

         X=0      🟢 Yesil baslangic kapisi
         X=3.0    S1: Sabit kutu (sinif 1)
         X=6.0    S2: Ince direk (sinif 2)
         X=8.5    S3: Cukur + uyari koni (sinif 3) — koni y=0
         X=11.0   S4: Esik (sinif 4) — kerb y=0
         X=13.5   S5: Yaya (sinif 5)
         X=16.0   S6: Dar koridor (sinif 6) — 1.5m genis, robot icinden
         X=19.0   S7: Riskli zemin + kucuk engel (sinif 7)
         X=22.0   🟥 Kirmizi bitis kapisi

         Tum engeller y=0'da. Sinir duvarlari y=±3 m. Parkur 24 m.
         ================================================================= -->

    <physics name="1ms" type="ignored">
      <max_step_size>0.002</max_step_size>
      <real_time_factor>1.0</real_time_factor>
    </physics>

    <plugin filename="gz-sim-physics-system" name="gz::sim::systems::Physics"/>
    <plugin filename="gz-sim-user-commands-system" name="gz::sim::systems::UserCommands"/>
    <plugin filename="gz-sim-scene-broadcaster-system" name="gz::sim::systems::SceneBroadcaster"/>
    <plugin filename="gz-sim-contact-system" name="gz::sim::systems::Contact"/>
    <plugin filename="gz-sim-imu-system" name="gz::sim::systems::Imu"/>
    <plugin filename="gz-sim-sensors-system" name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>
    <plugin filename="gz-sim-navsat-system" name="gz::sim::systems::NavSat"/>

    <gravity>0 0 -9.81</gravity>
    <magnetic_field>6e-06 2.3e-05 -4.2e-05</magnetic_field>

    <scene>
      <ambient>0.55 0.55 0.6 1</ambient>
      <background>0.65 0.78 0.92 1</background>
      <grid>false</grid>
    </scene>

    <light type="directional" name="sun">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.9 0.9 0.88 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <direction>-0.4 0.2 -0.9</direction>
    </light>

    <spherical_coordinates>
      <surface_model>EARTH_WGS84</surface_model>
      <world_frame_orientation>ENU</world_frame_orientation>
      <latitude_deg>41.015137</latitude_deg>
      <longitude_deg>28.979530</longitude_deg>
      <elevation>40.0</elevation>
    </spherical_coordinates>

    <!-- ═══════════════════════════════════════════════════════════════
         ZEMIN — gri beton
         ═══════════════════════════════════════════════════════════════ -->
    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="c">
          <geometry><plane><normal>0 0 1</normal><size>60 30</size></plane></geometry>
          <surface><friction><ode><mu>1.0</mu><mu2>1.0</mu2></ode></friction></surface>
        </collision>
        <visual name="v">
          <geometry><plane><normal>0 0 1</normal><size>60 30</size></plane></geometry>
          <material><ambient>0.42 0.42 0.44 1</ambient><diffuse>0.52 0.52 0.54 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- ═══════════════════════════════════════════════════════════════
         SINIR DUVARLARI — y=±3 m, parkur boyu 24 m (-1 .. +23)
         ═══════════════════════════════════════════════════════════════ -->
    <model name="boundary_wall_north">
      <static>true</static>
      <pose>11.0 3.0 0.25 0 0 0</pose>
      <link name="link">
        <collision name="c"><geometry><box><size>25.0 0.10 0.50</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>25.0 0.10 0.50</size></box></geometry>
          <material><ambient>0.78 0.78 0.80 1</ambient><diffuse>0.85 0.85 0.88 1</diffuse></material>
        </visual>
      </link>
    </model>
    <model name="boundary_wall_south">
      <static>true</static>
      <pose>11.0 -3.0 0.25 0 0 0</pose>
      <link name="link">
        <collision name="c"><geometry><box><size>25.0 0.10 0.50</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>25.0 0.10 0.50</size></box></geometry>
          <material><ambient>0.78 0.78 0.80 1</ambient><diffuse>0.85 0.85 0.88 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- ═══════════════════════════════════════════════════════════════
         BASLANGIC KAPISI — yesil, x=0, y simetrik ±1.2
         ═══════════════════════════════════════════════════════════════ -->
    <model name="start_gate_left">
      <static>true</static><pose>0.0 1.2 0.75 0 0 0</pose>
      <link name="link"><visual name="v"><geometry><box><size>0.10 0.10 1.5</size></box></geometry>
        <material><ambient>0.20 0.50 0.20 1</ambient><diffuse>0.30 0.70 0.30 1</diffuse></material>
      </visual></link>
    </model>
    <model name="start_gate_right">
      <static>true</static><pose>0.0 -1.2 0.75 0 0 0</pose>
      <link name="link"><visual name="v"><geometry><box><size>0.10 0.10 1.5</size></box></geometry>
        <material><ambient>0.20 0.50 0.20 1</ambient><diffuse>0.30 0.70 0.30 1</diffuse></material>
      </visual></link>
    </model>
    <model name="start_gate_beam">
      <static>true</static><pose>0.0 0 1.55 0 0 0</pose>
      <link name="link"><visual name="v"><geometry><box><size>0.10 2.6 0.10</size></box></geometry>
        <material><ambient>0.30 0.70 0.30 1</ambient><diffuse>0.30 0.70 0.30 1</diffuse></material>
      </visual></link>
    </model>

    <!-- ═══════════════════════════════════════════════════════════════
         ISTASYON 1 (X=3.0) — SINIF 1: Sabit kutu (centerline)
         Kirmizi 0.50 m kup. Robot doner.
         ═══════════════════════════════════════════════════════════════ -->
    <model name="s1_box_red">
      <static>true</static>
      <pose>3.0 0 0.25 0 0 0</pose>
      <link name="link">
        <collision name="c"><geometry><box><size>0.50 0.50 0.50</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>0.50 0.50 0.50</size></box></geometry>
          <material><ambient>0.80 0.20 0.20 1</ambient><diffuse>0.90 0.25 0.25 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- ═══════════════════════════════════════════════════════════════
         ISTASYON 2 (X=6.0) — SINIF 2: Ince direk (centerline)
         Ø 8 cm × 1.5 m. Lidar zayif algi; collision_monitor 30cm StopZone
         son savunma. Direk centerline'da -> robot mecbur doner.
         ═══════════════════════════════════════════════════════════════ -->
    <model name="s2_thin_pole">
      <static>true</static>
      <pose>6.0 0 0.75 0 0 0</pose>
      <link name="link">
        <collision name="c"><geometry><cylinder><radius>0.04</radius><length>1.50</length></cylinder></geometry></collision>
        <visual name="v"><geometry><cylinder><radius>0.04</radius><length>1.50</length></cylinder></geometry>
          <material><ambient>0.40 0.30 0.20 1</ambient><diffuse>0.50 0.40 0.30 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- ═══════════════════════════════════════════════════════════════
         ISTASYON 3 (X=8.5) — SINIF 3: Negatif + uyari koni (centerline)
         Turuncu koni y=0 → fiziksel engel olarak avoider dener. Cukur
         visual sadece tezdeki "neyi temsil ediyor" notasyonu.
         ═══════════════════════════════════════════════════════════════ -->
    <model name="s3_warning_cone">
      <static>true</static>
      <pose>8.5 0 0.25 0 0 0</pose>
      <link name="link">
        <collision name="c"><geometry><cylinder><radius>0.15</radius><length>0.50</length></cylinder></geometry></collision>
        <visual name="v"><geometry><cylinder><radius>0.15</radius><length>0.50</length></cylinder></geometry>
          <material><ambient>0.95 0.50 0.10 1</ambient><diffuse>1.00 0.60 0.15 1</diffuse></material>
        </visual>
      </link>
    </model>
    <!-- Pothole görseli — gerçek robotta terrain_perception tespit eder -->
    <model name="s3_pothole_visual">
      <static>true</static>
      <pose>8.5 0.7 0.005 0 0 0</pose>
      <link name="link">
        <visual name="v">
          <geometry><cylinder><radius>0.25</radius><length>0.01</length></cylinder></geometry>
          <material><ambient>0.10 0.10 0.10 1</ambient><diffuse>0.05 0.05 0.05 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- ═══════════════════════════════════════════════════════════════
         ISTASYON 4 (X=11.0) — SINIF 4: Esik (centerline)
         15 cm yukseklikte mavi blok. Robot tirmanamaz, kacinmali.
         Yan tarafta yumusak rampa (5 cm) — alternatif yol.
         ═══════════════════════════════════════════════════════════════ -->
    <model name="s4_kerb_step">
      <static>true</static>
      <pose>11.0 0 0.075 0 0 0</pose>
      <link name="link">
        <collision name="c"><geometry><box><size>0.40 1.20 0.15</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>0.40 1.20 0.15</size></box></geometry>
          <material><ambient>0.20 0.30 0.70 1</ambient><diffuse>0.25 0.35 0.80 1</diffuse></material>
        </visual>
      </link>
    </model>
    <!-- Yumusak rampa alternatif yol (sol, y=+1.5) -->
    <model name="s4_ramp_safe">
      <static>true</static>
      <pose>11.0 1.5 0.025 0 0.05 0</pose>
      <link name="link">
        <visual name="v"><geometry><box><size>1.5 0.8 0.05</size></box></geometry>
          <material><ambient>0.30 0.50 0.30 1</ambient><diffuse>0.40 0.60 0.40 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- ═══════════════════════════════════════════════════════════════
         ISTASYON 5 (X=13.5) — SINIF 5: Yaya (centerline)
         Insan modeli y=0. Lidar 90cm gövdeyi gorur.
         ═══════════════════════════════════════════════════════════════ -->
    <model name="s5_person">
      <static>true</static>
      <pose>13.5 0 0.0 0 0 0</pose>
      <link name="link">
        <collision name="body"><pose>0 0 0.45 0 0 0</pose>
          <geometry><cylinder><radius>0.20</radius><length>0.90</length></cylinder></geometry></collision>
        <visual name="body_v"><pose>0 0 0.45 0 0 0</pose>
          <geometry><cylinder><radius>0.20</radius><length>0.90</length></cylinder></geometry>
          <material><ambient>0.20 0.30 0.70 1</ambient><diffuse>0.25 0.35 0.80 1</diffuse></material>
        </visual>
        <collision name="head"><pose>0 0 1.05 0 0 0</pose>
          <geometry><sphere><radius>0.13</radius></sphere></geometry></collision>
        <visual name="head_v"><pose>0 0 1.05 0 0 0</pose>
          <geometry><sphere><radius>0.13</radius></sphere></geometry>
          <material><ambient>0.92 0.74 0.55 1</ambient><diffuse>0.95 0.78 0.58 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- ═══════════════════════════════════════════════════════════════
         ISTASYON 6 (X=15.5-17.5) — SINIF 6: Dar koridor (centerline)
         Iki paralel duvar y=±0.75, robot icinden gecmek zorunda.
         Robot 0.50m genis, koridor 1.5m -> her yanda 0.50m marj.
         Centerline koridor merkezi de y=0 -> robot direkt icine sürer.
         ═══════════════════════════════════════════════════════════════ -->
    <model name="s6_corridor_wall_left">
      <static>true</static>
      <pose>16.5 0.75 0.35 0 0 0</pose>
      <link name="link">
        <collision name="c"><geometry><box><size>2.0 0.20 0.70</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>2.0 0.20 0.70</size></box></geometry>
          <material><ambient>0.60 0.40 0.30 1</ambient><diffuse>0.70 0.50 0.40 1</diffuse></material>
        </visual>
      </link>
    </model>
    <model name="s6_corridor_wall_right">
      <static>true</static>
      <pose>16.5 -0.75 0.35 0 0 0</pose>
      <link name="link">
        <collision name="c"><geometry><box><size>2.0 0.20 0.70</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>2.0 0.20 0.70</size></box></geometry>
          <material><ambient>0.60 0.40 0.30 1</ambient><diffuse>0.70 0.50 0.40 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- ═══════════════════════════════════════════════════════════════
         ISTASYON 7 (X=19.5) — SINIF 7: Riskli zemin + kucuk engel
         Yesil/sari/kirmizi patches. Centerline'da kucuk yesil silindir
         engel (lidar gorur) — robot doner.
         ═══════════════════════════════════════════════════════════════ -->
    <model name="s7_box_green">
      <static>true</static>
      <pose>19.5 0 0.20 0 0 0</pose>
      <link name="link">
        <collision name="c"><geometry><box><size>0.40 0.40 0.40</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>0.40 0.40 0.40</size></box></geometry>
          <material><ambient>0.20 0.65 0.30 1</ambient><diffuse>0.25 0.75 0.35 1</diffuse></material>
        </visual>
      </link>
    </model>
    <!-- Riskli zemin patches (visual only) -->
    <model name="s7_surface_safe">
      <static>true</static>
      <pose>19.5 1.5 0.005 0 0 0</pose>
      <link name="link">
        <visual name="v">
          <geometry><box><size>1.2 0.8 0.01</size></box></geometry>
          <material><ambient>0.20 0.65 0.30 1</ambient><diffuse>0.25 0.75 0.35 1</diffuse></material>
        </visual>
      </link>
    </model>
    <model name="s7_surface_caution">
      <static>true</static>
      <pose>19.5 -1.5 0.005 0 0 0</pose>
      <link name="link">
        <visual name="v">
          <geometry><box><size>1.2 0.8 0.01</size></box></geometry>
          <material><ambient>0.85 0.80 0.20 1</ambient><diffuse>0.95 0.90 0.25 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- ═══════════════════════════════════════════════════════════════
         BITIS KAPISI — kirmizi, x=22.0 — start ile aynı hizada (y simetrik)
         ═══════════════════════════════════════════════════════════════ -->
    <model name="finish_gate_left">
      <static>true</static><pose>22.0 1.2 0.75 0 0 0</pose>
      <link name="link"><visual name="v"><geometry><box><size>0.10 0.10 1.5</size></box></geometry>
        <material><ambient>0.70 0.15 0.15 1</ambient><diffuse>0.80 0.20 0.20 1</diffuse></material>
      </visual></link>
    </model>
    <model name="finish_gate_right">
      <static>true</static><pose>22.0 -1.2 0.75 0 0 0</pose>
      <link name="link"><visual name="v"><geometry><box><size>0.10 0.10 1.5</size></box></geometry>
        <material><ambient>0.70 0.15 0.15 1</ambient><diffuse>0.80 0.20 0.20 1</diffuse></material>
      </visual></link>
    </model>
    <model name="finish_gate_beam">
      <static>true</static><pose>22.0 0 1.55 0 0 0</pose>
      <link name="link"><visual name="v"><geometry><box><size>0.10 2.6 0.10</size></box></geometry>
        <material><ambient>0.80 0.20 0.20 1</ambient><diffuse>0.80 0.20 0.20 1</diffuse></material>
      </visual></link>
    </model>

    <!-- ═══════════════════════════════════════════════════════════════
         ISTASYON LEVHALARI — her istasyonun yaninda dikey beyaz direk
         ═══════════════════════════════════════════════════════════════ -->
    <model name="sign_s1"><static>true</static><pose>3.0 -2.5 0.75 0 0 0</pose>
      <link name="link"><visual name="v"><geometry><box><size>0.05 0.05 1.5</size></box></geometry>
        <material><ambient>0.95 0.95 0.95 1</ambient></material></visual></link></model>
    <model name="sign_s2"><static>true</static><pose>6.0 -2.5 0.75 0 0 0</pose>
      <link name="link"><visual name="v"><geometry><box><size>0.05 0.05 1.5</size></box></geometry>
        <material><ambient>0.95 0.95 0.95 1</ambient></material></visual></link></model>
    <model name="sign_s3"><static>true</static><pose>8.5 -2.5 0.75 0 0 0</pose>
      <link name="link"><visual name="v"><geometry><box><size>0.05 0.05 1.5</size></box></geometry>
        <material><ambient>0.95 0.95 0.95 1</ambient></material></visual></link></model>
    <model name="sign_s4"><static>true</static><pose>11.0 -2.5 0.75 0 0 0</pose>
      <link name="link"><visual name="v"><geometry><box><size>0.05 0.05 1.5</size></box></geometry>
        <material><ambient>0.95 0.95 0.95 1</ambient></material></visual></link></model>
    <model name="sign_s5"><static>true</static><pose>13.5 -2.5 0.75 0 0 0</pose>
      <link name="link"><visual name="v"><geometry><box><size>0.05 0.05 1.5</size></box></geometry>
        <material><ambient>0.95 0.95 0.95 1</ambient></material></visual></link></model>
    <model name="sign_s6"><static>true</static><pose>16.5 -2.5 0.75 0 0 0</pose>
      <link name="link"><visual name="v"><geometry><box><size>0.05 0.05 1.5</size></box></geometry>
        <material><ambient>0.95 0.95 0.95 1</ambient></material></visual></link></model>
    <model name="sign_s7"><static>true</static><pose>19.5 -2.5 0.75 0 0 0</pose>
      <link name="link"><visual name="v"><geometry><box><size>0.05 0.05 1.5</size></box></geometry>
        <material><ambient>0.95 0.95 0.95 1</ambient></material></visual></link></model>

  </world>
</sdf>
