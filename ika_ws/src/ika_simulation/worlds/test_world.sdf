<?xml version="1.0"?>
<sdf version="1.10">
  <world name="ika_test_world">

    <!-- =================================================================
         IKA Engel Kacinma Test Pisti — sade
         =================================================================
         Robot start (0,0) +X yonune. 5 engel y=0 ekseninde, 3 m araliklarla.
         Robot dumduz ilerler, her engele yaklasinca lidar gorur, saga veya
         sola doner, etrafindan dolanir, devam eder.
         Engeller:
           obs_1  (3, 0)  kutu  0.5 m kup
           obs_2  (6, 0)  kutu  0.6 m kup
           obs_3  (9, 0)  silindir Ø 0.5
           obs_4  (12, 0) yaya (silindir + kafa)
           obs_5  (15, 0) kutu  0.7 m kup
         Sinir duvarlari: y=±3 m, 0.5 m yukseklik (lidar gorur).
         Bitis kemeri: (18, 0).
         ================================================================= -->

    <physics name="1ms" type="ignored">
      <max_step_size>0.002</max_step_size>
      <real_time_factor>1.0</real_time_factor>
    </physics>

    <plugin filename="gz-sim-physics-system" name="gz::sim::systems::Physics"/>
    <plugin filename="gz-sim-user-commands-system" name="gz::sim::systems::UserCommands"/>
    <plugin filename="gz-sim-scene-broadcaster-system" name="gz::sim::systems::SceneBroadcaster"/>
    <plugin filename="gz-sim-contact-system" name="gz::sim::systems::Contact"/>
    <plugin filename="gz-sim-imu-system" name="gz::sim::systems::Imu"/>
    <plugin filename="gz-sim-sensors-system" name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>
    <plugin filename="gz-sim-navsat-system" name="gz::sim::systems::NavSat"/>

    <gravity>0 0 -9.81</gravity>
    <magnetic_field>6e-06 2.3e-05 -4.2e-05</magnetic_field>

    <scene>
      <ambient>0.55 0.55 0.6 1</ambient>
      <background>0.65 0.78 0.92 1</background>
      <grid>false</grid>
    </scene>

    <light type="directional" name="sun">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.9 0.9 0.88 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <direction>-0.4 0.2 -0.9</direction>
    </light>

    <spherical_coordinates>
      <surface_model>EARTH_WGS84</surface_model>
      <world_frame_orientation>ENU</world_frame_orientation>
      <latitude_deg>41.015137</latitude_deg>
      <longitude_deg>28.979530</longitude_deg>
      <elevation>40.0</elevation>
    </spherical_coordinates>

    <!-- =========================  ZEMIN  ========================= -->
    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="c">
          <geometry><plane><normal>0 0 1</normal><size>50 50</size></plane></geometry>
          <surface><friction><ode><mu>1.0</mu><mu2>1.0</mu2></ode></friction></surface>
        </collision>
        <visual name="v">
          <geometry><plane><normal>0 0 1</normal><size>50 50</size></plane></geometry>
          <material><ambient>0.42 0.42 0.44 1</ambient><diffuse>0.52 0.52 0.54 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- =========================  SINIR DUVARLARI  ========================= -->
    <model name="boundary_wall_north">
      <static>true</static>
      <pose>9.0 3.0 0.25 0 0 0</pose>
      <link name="link">
        <collision name="c"><geometry><box><size>20.0 0.10 0.50</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>20.0 0.10 0.50</size></box></geometry>
          <material><ambient>0.78 0.78 0.80 1</ambient><diffuse>0.85 0.85 0.88 1</diffuse></material>
        </visual>
      </link>
    </model>
    <model name="boundary_wall_south">
      <static>true</static>
      <pose>9.0 -3.0 0.25 0 0 0</pose>
      <link name="link">
        <collision name="c"><geometry><box><size>20.0 0.10 0.50</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>20.0 0.10 0.50</size></box></geometry>
          <material><ambient>0.78 0.78 0.80 1</ambient><diffuse>0.85 0.85 0.88 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- =========================  ENGEL 1 — Kirmizi kutu (3, 0)  ========================= -->
    <model name="obs_1">
      <static>true</static>
      <pose>3.0 0 0.25 0 0 0</pose>
      <link name="link">
        <collision name="c"><geometry><box><size>0.50 0.50 0.50</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>0.50 0.50 0.50</size></box></geometry>
          <material><ambient>0.80 0.20 0.20 1</ambient><diffuse>0.90 0.25 0.25 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- =========================  ENGEL 2 — Mavi kutu (6, 0)  ========================= -->
    <model name="obs_2">
      <static>true</static>
      <pose>6.0 0 0.30 0 0 0</pose>
      <link name="link">
        <collision name="c"><geometry><box><size>0.60 0.60 0.60</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>0.60 0.60 0.60</size></box></geometry>
          <material><ambient>0.20 0.30 0.80 1</ambient><diffuse>0.25 0.35 0.90 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- =========================  ENGEL 3 — Sari silindir (9, 0)  ========================= -->
    <model name="obs_3">
      <static>true</static>
      <pose>9.0 0 0.35 0 0 0</pose>
      <link name="link">
        <collision name="c"><geometry><cylinder><radius>0.25</radius><length>0.70</length></cylinder></geometry></collision>
        <visual name="v"><geometry><cylinder><radius>0.25</radius><length>0.70</length></cylinder></geometry>
          <material><ambient>0.95 0.85 0.20 1</ambient><diffuse>1.00 0.95 0.25 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- =========================  ENGEL 4 — Yaya (12, 0)  ========================= -->
    <model name="obs_4_person">
      <static>true</static>
      <pose>12.0 0 0.0 0 0 0</pose>
      <link name="link">
        <collision name="body"><pose>0 0 0.45 0 0 0</pose>
          <geometry><cylinder><radius>0.20</radius><length>0.90</length></cylinder></geometry></collision>
        <visual name="body_v"><pose>0 0 0.45 0 0 0</pose>
          <geometry><cylinder><radius>0.20</radius><length>0.90</length></cylinder></geometry>
          <material><ambient>0.20 0.30 0.70 1</ambient><diffuse>0.25 0.35 0.80 1</diffuse></material>
        </visual>
        <collision name="head"><pose>0 0 1.05 0 0 0</pose>
          <geometry><sphere><radius>0.13</radius></sphere></geometry></collision>
        <visual name="head_v"><pose>0 0 1.05 0 0 0</pose>
          <geometry><sphere><radius>0.13</radius></sphere></geometry>
          <material><ambient>0.92 0.74 0.55 1</ambient><diffuse>0.95 0.78 0.58 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- =========================  ENGEL 5 — Buyuk yesil kutu (15, 0)  ========================= -->
    <model name="obs_5">
      <static>true</static>
      <pose>15.0 0 0.35 0 0 0</pose>
      <link name="link">
        <collision name="c"><geometry><box><size>0.70 0.70 0.70</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>0.70 0.70 0.70</size></box></geometry>
          <material><ambient>0.20 0.65 0.30 1</ambient><diffuse>0.25 0.75 0.35 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- =========================  BASLANGIC / BITIS KEMERI  ========================= -->
    <model name="start_gate_left">
      <static>true</static><pose>-0.5 1.2 0.75 0 0 0</pose>
      <link name="link">
        <collision name="c"><geometry><box><size>0.10 0.10 1.5</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>0.10 0.10 1.5</size></box></geometry>
          <material><ambient>0.20 0.50 0.20 1</ambient><diffuse>0.30 0.70 0.30 1</diffuse></material>
        </visual>
      </link>
    </model>
    <model name="start_gate_right">
      <static>true</static><pose>-0.5 -1.2 0.75 0 0 0</pose>
      <link name="link">
        <collision name="c"><geometry><box><size>0.10 0.10 1.5</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>0.10 0.10 1.5</size></box></geometry>
          <material><ambient>0.20 0.50 0.20 1</ambient><diffuse>0.30 0.70 0.30 1</diffuse></material>
        </visual>
      </link>
    </model>
    <model name="start_gate_beam">
      <static>true</static><pose>-0.5 0 1.55 0 0 0</pose>
      <link name="link">
        <visual name="v"><geometry><box><size>0.10 2.6 0.10</size></box></geometry>
          <material><ambient>0.30 0.70 0.30 1</ambient><diffuse>0.30 0.70 0.30 1</diffuse></material>
        </visual>
      </link>
    </model>

    <model name="finish_gate_left">
      <static>true</static><pose>18.0 1.2 0.75 0 0 0</pose>
      <link name="link">
        <collision name="c"><geometry><box><size>0.10 0.10 1.5</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>0.10 0.10 1.5</size></box></geometry>
          <material><ambient>0.70 0.15 0.15 1</ambient><diffuse>0.80 0.20 0.20 1</diffuse></material>
        </visual>
      </link>
    </model>
    <model name="finish_gate_right">
      <static>true</static><pose>18.0 -1.2 0.75 0 0 0</pose>
      <link name="link">
        <collision name="c"><geometry><box><size>0.10 0.10 1.5</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>0.10 0.10 1.5</size></box></geometry>
          <material><ambient>0.70 0.15 0.15 1</ambient><diffuse>0.80 0.20 0.20 1</diffuse></material>
        </visual>
      </link>
    </model>
    <model name="finish_gate_beam">
      <static>true</static><pose>18.0 0 1.55 0 0 0</pose>
      <link name="link">
        <visual name="v"><geometry><box><size>0.10 2.6 0.10</size></box></geometry>
          <material><ambient>0.80 0.20 0.20 1</ambient><diffuse>0.80 0.20 0.20 1</diffuse></material>
        </visual>
      </link>
    </model>

  </world>
</sdf>
