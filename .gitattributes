# Tum metin dosyalari LF (Linux/ROS2 hedef sistem).
* text=auto eol=lf

# Garanti LF (script ve config'lerin Windows tarafindan CRLF'lenmemesi icin)
*.sh   text eol=lf
*.py   text eol=lf
*.yaml text eol=lf
*.yml  text eol=lf
*.xml  text eol=lf
*.xacro text eol=lf
*.urdf text eol=lf
*.sdf  text eol=lf
*.md   text eol=lf
*.ino  text eol=lf
*.cpp  text eol=lf
*.hpp  text eol=lf
*.h    text eol=lf
*.txt  text eol=lf
*.cfg  text eol=lf
CMakeLists.txt text eol=lf
Dockerfile     text eol=lf
.gitignore     text eol=lf
.gitattributes text eol=lf

# Binary dosyalar (var olursa)
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.pdf  binary
*.dae  binary
*.stl  binary
*.bag  binary
*.db3  binary
*.mcap binary
